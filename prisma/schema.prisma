// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  role      String   @default("ADMIN")
  createdAt DateTime @default(now())
}

model Product {
  id         Int       @id @default(autoincrement())
  name       String
  weight     Int
  serialCode String    @unique
  price      Float?
  stock      Int?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  qrRecord   QrRecord?
}

/// Archived copy of deleted products for recovery
model ProductDeleteHistory {
  id                Int                 @id @default(autoincrement())
  productId         Int
  name              String
  weight            Int
  serialCode        String
  price             Float?
  stock             Int?
  qrImageUrl        String?
  scanCount         Int?                @default(0)
  deletedBy         String?
  deletedAt         DateTime            @default(now())
  restoredAt        DateTime?
  restoredProductId Int?
  notes             String?
  batchId           Int?
  batch             ProductDeleteBatch? @relation(fields: [batchId], references: [id])

  @@index([deletedAt])
  @@index([serialCode])
}

/// Group of deleted items in one operation
model ProductDeleteBatch {
  id        Int                    @id @default(autoincrement())
  deletedAt DateTime               @default(now())
  deletedBy String?
  itemCount Int
  histories ProductDeleteHistory[]

  @@index([deletedAt])
}

/// CMS-facing product data for the public products page
/// This is intentionally separated from the QR `Product` model above so that
/// marketing content (images, copywriting, pricing display) can evolve
/// independently from the verification inventory.
model CmsProduct {
  id               Int      @id @default(autoincrement())
  name             String
  weight           String
  price            Float?
  /// Array of image URLs or paths (e.g. `/images/50gr.jpeg`)
  images           Json?
  /// Filter category: all, award-winning, exclusives, large-bars, small-bars
  filterCategory   String?  @default("all")
  /// Auto-filled fields for consistency
  rangeName        String?
  purity           String?
  category         String?
  description      String?
  /// If this CMS product overrides a default product, store the default ID
  /// This allows "editing" default products by creating CMS overrides
  /// Format: "default-1", "default-2", "default-3"
  overridesDefault String?  @unique
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model QrRecord {
  id            Int         @id @default(autoincrement())
  productId     Int         @unique
  serialCode    String      @unique
  qrImageUrl    String
  scanCount     Int         @default(0)
  lastScannedAt DateTime?
  createdAt     DateTime    @default(now())
  product       Product     @relation(fields: [productId], references: [id])
  scanLogs      QRScanLog[]
}

model QRScanLog {
  id         Int      @id @default(autoincrement())
  qrRecordId Int
  scannedAt  DateTime @default(now())
  ip         String?
  userAgent  String?
  location   String?
  qrRecord   QrRecord @relation(fields: [qrRecordId], references: [id])
}

/// New generation inventory - gram-based batches and per-QR uniq codes
/// IMPORTANT:
/// - This does NOT change or reuse the existing Product / QrRecord tables
/// - Page 1 (current admin Products & QR Preview) continues to use Product/QrRecord
/// - Page 2 (new gram-based flow) will use GramProductBatch / GramProductItem
/// - Verification API will be extended to also look up GramProductItem by uniqCode

model GramProductBatch {
  id          Int               @id @default(autoincrement())
  /// Human readable product name (e.g. "Silver King 250gr")
  name        String
  /// Weight in grams (e.g. 50, 100, 250, 500)
  weight      Int
  /// Total quantity represented by this batch input
  quantity    Int
  /// Mode derived from weight:
  /// - "SINGLE_QR" for small weights (e.g. 50, 100) -> 1 QR for whole batch
  /// - "PER_UNIT_QR" for large weights (e.g. 250, 500, 1000, ...) -> 1 QR per unit
  qrMode      String
  /// Optional grouping or category label (e.g. "SMALL", "LARGE")
  weightGroup String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  /// One-to-many relation to concrete QR items / uniq codes
  items       GramProductItem[]
}

model GramProductItem {
  id            Int              @id @default(autoincrement())
  batchId       Int
  /// Stable uniq code printed on the QR and used for verification lookup
  /// NOTE: NOT unique - multiple items in a batch can share the same uniqCode
  /// Root key is used to differentiate items with the same uniqCode
  uniqCode      String
  /// Serial code (SKP format) - required for Page 2
  /// This MUST be unique per item
  serialCode    String           @unique
  /// Root key hash (bcrypt) for two-step verification - alphanumeric 3-4 chars
  rootKeyHash   String
  /// Root key plain text (for admin display only) - stored separately from hash for admin convenience
  rootKey       String?
  qrImageUrl    String
  scanCount     Int              @default(0)
  lastScannedAt DateTime?
  createdAt     DateTime         @default(now())
  batch         GramProductBatch @relation(fields: [batchId], references: [id])
  scanLogs      GramQRScanLog[]

  /// Index for faster lookups by uniqCode (since multiple items can have same uniqCode)
  @@index([uniqCode])
}

model GramQRScanLog {
  id        Int             @id @default(autoincrement())
  qrItemId  Int
  scannedAt DateTime        @default(now())
  ip        String?
  userAgent String?
  location  String?
  qrItem    GramProductItem @relation(fields: [qrItemId], references: [id])
}

/// Daily scan summary for historical months (raw logs exported to R2 and purged)
/// Used by analytics chart "Scans over time" - reads from here for past months
model ScanLogSummary {
  id          Int      @id @default(autoincrement())
  date        DateTime @db.Date
  page1Scans  Int      @default(0)
  page2Scans  Int      @default(0)
  totalScans  Int      @default(0)

  @@unique([date])
  @@index([date])
}

/// Serticard custom config - single row (id=1)
/// Admin can upload custom templates and configure font
model SerticardConfig {
  id               Int       @id @default(1)
  customFrontR2Key String?   // e.g. templates/serticard-custom-front.png
  customBackR2Key  String?   // e.g. templates/serticard-custom-back.png
  fontFamily       String    @default("Arial")   // Arial | Lucida Sans | Times New Roman | SF Mono
  fontSizePreset   String    @default("BESAR")   // BESAR | KECIL
  updatedAt        DateTime  @updatedAt
}

/// Distributor locations - managed via admin
model Distributor {
  id          Int      @id @default(autoincrement())
  name        String   // Nama distributor (e.g. Youceu)
  storeName   String?  // Nama toko (e.g. Toko Kang Emas)
  address     String   @db.Text // Alamat lengkap
  phone       String   // Nomor telepon untuk transaksi
  mapUrl      String?  @db.Text // Link Google Maps
  city        String   // Kota/region (e.g. Bandung, Tasikmalaya)
  displayOrder Int     @default(0) // Urutan tampilan
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([city])
  @@index([displayOrder])
}

/// Contact form feedback messages from users
model Feedback {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  message   String   @db.Text
  createdAt DateTime @default(now())
  read      Boolean  @default(false)

  @@index([createdAt])
  @@index([read])
}
